# LLM 配置
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

# 超时和重试
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# 报告质量评审（LLM review）
REPORT_REVIEW_LLM_ENABLED=false

# 飞书机器人
# FEISHU_BOT_ENABLED=true
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_EVENT_MODE=long_connection
# PUBLIC_REPORT_BASE_URL=http://127.0.0.1:8000
# BACKEND_BASE_URL=http://127.0.0.1:8000

# P6.0 评论聚类
COMMENT_CLUSTERING_ENABLED=true
COMMENT_CLUSTER_SIM_THRESHOLD=0.72
COMMENT_CLUSTER_MIN_SIZE=2
COMMENT_CLUSTER_TOP_K=5
EMBEDDING_PROVIDER=bailian
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT=30
